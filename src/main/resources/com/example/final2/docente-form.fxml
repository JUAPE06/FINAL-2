<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.final2.controller.DocenteFormController"
      spacing="14"
      style="-fx-padding:24; -fx-background-color:white;"
      prefWidth="450">

    <Label fx:id="lblTitulo" text="Registro de Docente"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#1565C0;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="120" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>

        <Label text="DNI: *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtDni" promptText="8 dígitos" maxWidth="Infinity"/>
            <Label fx:id="lblDniError" text="" style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Nombres: *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtNombres" promptText="Nombres completos" maxWidth="Infinity"/>
            <Label fx:id="lblNombresError" text="" style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Apellidos: *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="2" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtApellidos" promptText="Apellidos completos" maxWidth="Infinity"/>
            <Label fx:id="lblApellidosError" text="" style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Especialidad:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEspecialidad" promptText="Ejem: Matemática, Comunicación" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Condición:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cboCondicion" promptText="Seleccione condición" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="(*) Campo obligatorio" style="-fx-font-size:11; -fx-text-fill:#757575;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" prefWidth="100" style="-fx-cursor:hand;"/>
        <Button text="Guardar" onAction="#onGuardar" defaultButton="true" prefWidth="100"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>
</VBox>
