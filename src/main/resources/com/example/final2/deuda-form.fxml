<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.final2.controller.DeudaFormController"
      spacing="14"
      style="-fx-padding:24; -fx-background-color:white;"
      prefWidth="500">

    <Label fx:id="lblTitulo" text="Registro de Deuda Administrativa"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#2E7D32;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="130" prefWidth="140" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="260"/>
        </columnConstraints>

        <Label text="Docente: *" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="2">
            <ComboBox fx:id="cboDocente" promptText="Seleccione docente" maxWidth="Infinity"/>
            <Label fx:id="lblDocenteError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Concepto: *" GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtConcepto" promptText="Ingrese concepto de la deuda..." maxWidth="Infinity"/>
            <Label fx:id="lblConceptoError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Monto (S/): *" GridPane.rowIndex="2" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="2" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtMonto" promptText="0.00" maxWidth="Infinity"/>
            <Label fx:id="lblMontoError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Fecha Registro: *" GridPane.rowIndex="3" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="2">
            <DatePicker fx:id="dpFecha" maxWidth="Infinity"/>
            <Label fx:id="lblFechaError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <Label text="Estado: *" GridPane.rowIndex="4" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="4" GridPane.columnIndex="1" spacing="2">
            <ComboBox fx:id="cboEstado" promptText="Seleccione estado" maxWidth="Infinity"/>
            <Label fx:id="lblEstadoError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>
    </GridPane>

    <Label text="(*) Campo obligatorio"
           style="-fx-font-size:11; -fx-text-fill:#757575;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"
                prefWidth="100"
                style="-fx-cursor:hand;"/>
        <Button text="Guardar" onAction="#onGuardar"
                defaultButton="true" prefWidth="100"
                style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>
</VBox>
