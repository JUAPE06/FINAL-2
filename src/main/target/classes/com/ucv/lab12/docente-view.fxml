<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.DocenteController"
      spacing="10"
      style="-fx-padding:15; -fx-background-color:#F5F5F5;">

    <Label text="Mantenimiento de Docentes - UGEL Ilo"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#1565C0;">
        <font><Font size="22.0"/></font>
    </Label>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color:#E3F2FD; -fx-padding:10; -fx-background-radius:6;">
        <Label text="Buscar:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtBusqueda" promptText="DNI, Nombres o Apellidos..." prefWidth="300"/>
        <Button text="Buscar" onAction="#onBuscar"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="100"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ Nuevo Docente" onAction="#onCrear"
                style="-fx-background-color:#388E3C;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="170"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="Total: 0 registro(s)"
               style="-fx-font-style:italic; -fx-text-fill:#555;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white; -fx-border-color:#CFD8DC; -fx-border-radius:4;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="55" style="-fx-alignment:CENTER;"/>
            <TableColumn fx:id="colDni" text="DNI" prefWidth="100" style="-fx-alignment:CENTER;"/>
            <TableColumn fx:id="colNombres" text="Nombres" prefWidth="200"/>
            <TableColumn fx:id="colApellidos" text="Apellidos" prefWidth="200"/>
            <TableColumn fx:id="colEspecialidad" text="Especialidad" prefWidth="150"/>
            <TableColumn fx:id="colCondicion" text="Condición" prefWidth="120"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="155" style="-fx-alignment:CENTER;"/>
        </columns>
        <placeholder>
            <Label text="No hay docentes registrados." style="-fx-text-fill:#888;"/>
        </placeholder>
    </TableView>
</VBox>
